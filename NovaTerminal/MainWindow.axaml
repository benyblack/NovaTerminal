<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaTerminal.MainWindow"
        Title="NovaTerminal"
        Width="1200" Height="800"
        MinWidth="400" MinHeight="200"
        x:Name="RootWindow"
        Icon="avares://NovaTerminal/Assets/nova_icon.png"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        TransparencyLevelHint=""
        Background="Transparent">
    <Window.Resources>
        <DataTemplate x:Key="TabHeaderTemplate">
            <TextBlock Text="{Binding}" Foreground="White" 
                       FontSize="10" VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Padding="6,1,6,1"
                       Margin="0,0,0,0"/>
        </DataTemplate>
    </Window.Resources>
    <Window.Styles>
        <Style Selector="Button#BtnNewTab">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button#BtnNewTab:pointerover">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        <Style Selector="Button#SettingsBtn">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button#SettingsBtn:pointerover">
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>

        <!-- GridSplitter Custom Template for thinner lines with larger hit area -->
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent">
                        <Rectangle Name="PART_Line" Fill="{TemplateBinding Background}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="GridSplitter[ResizeDirection=Columns] /template/ Rectangle#PART_Line">
            <Setter Property="Width" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="GridSplitter[ResizeDirection=Rows] /template/ Rectangle#PART_Line">
            <Setter Property="Height" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>
    <Grid x:Name="MainRoot" Background="Transparent">
        <!-- Unified background layer for the entire window -->
        <Grid x:Name="WindowBackground" IsHitTestVisible="False" />

        <!-- TabControl spanning full window, headers in title bar area -->
        <TabControl Name="Tabs" Margin="0"
                    TabStripPlacement="Top"
                    Padding="0"
                    BorderThickness="0"
                    ZIndex="60"
                    RenderOptions.BitmapInterpolationMode="HighQuality">
            <TabControl.Styles>
                <Style Selector="TabControl">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <DockPanel>
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                              DockPanel.Dock="Top"
                                              ItemsPanel="{TemplateBinding ItemsPanel}" />
                                <ContentPresenter Name="PART_SelectedContentHost"
                                                Margin="0"
                                                Background="Transparent"
                                                Content="{TemplateBinding SelectedContent}"
                                                ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
                            </DockPanel>
                        </ControlTemplate>
                    </Setter>
                </Style>
            </TabControl.Styles>
            <!-- Tabs added dynamically -->
        </TabControl>

        <!-- Draggable area for window movement (MUST be after Tabs to be on top) -->
        <Border Name="DragBorder" 
                VerticalAlignment="Top" 
                Height="48" 
                Background="Transparent"
                ZIndex="50"
                Margin="0,0,0,0"/>

        <!-- Overlay layer for custom buttons (Right aligned, leaving space for system caption buttons) -->
        <Grid VerticalAlignment="Top" Height="32" HorizontalAlignment="Right" ZIndex="100" x:Name="TitleBar" Margin="0,4,140,0" Background="Transparent">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent">
                <!-- Focusable=False to prevent stealing keyboard focus on click -->
                <Button Name="BtnNewTab" Content="+" 
                        Foreground="White"
                        BorderThickness="0" Focusable="False" 
                        FontSize="18"
                        FontWeight="Light"
                        Padding="8,4" 
                        CornerRadius="4"
                        Margin="4,0,0,0"
                        ToolTip.Tip="New Tab">
                    <Button.Flyout>
                        <MenuFlyout>
                            <!-- Populated dynamically -->
                            <Separator />
                            <MenuItem Header="Manage Profiles..." Name="MenuManageProfiles" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Name="SettingsBtn" Content="⚙" 
                        Foreground="White"
                        BorderThickness="0" Focusable="False" 
                        FontSize="16"
                        Padding="8,4" 
                        CornerRadius="4"
                        Margin="4,0,0,0"
                        ToolTip.Tip="Settings"/>
            </StackPanel>
        </Grid>

        <!-- Search Overlay -->
        <Border Name="SearchPanel" IsVisible="False" VerticalAlignment="Top" HorizontalAlignment="Right" 
                Margin="0,50,20,0" Background="#383838" CornerRadius="4" Padding="6" Width="420"
                BorderBrush="#505050" BorderThickness="1" ZIndex="200">
            <Border.Resources>
                <SolidColorBrush x:Key="TextControlBackground">#1a1a1a</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver">#1a1a1a</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundFocused">#1a1a1a</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForeground">White</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver">White</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundFocused">White</SolidColorBrush>
            </Border.Resources>
            <Grid ColumnDefinitions="*, Auto, Auto, Auto, Auto">
                <TextBox Name="SearchBox" Watermark="Search..." 
                         BorderThickness="1" BorderBrush="#505050" 
                         VerticalContentAlignment="Center" 
                         Padding="8,4" Margin="2"/>
                <TextBlock Name="SearchCount" Grid.Column="1" Text="0/0" Foreground="#AAA" 
                           VerticalAlignment="Center" Margin="8,0" FontSize="12"/>
                <Button Name="SearchPrev" Grid.Column="2" Content="▲" Background="Transparent" Foreground="#AAA" BorderThickness="0" Margin="2" Width="30" Focusable="False"/>
                <Button Name="SearchNext" Grid.Column="3" Content="▼" Background="Transparent" Foreground="#AAA" BorderThickness="0" Margin="2" Width="30" Focusable="False"/>
                <Button Name="SearchClose" Grid.Column="4" Content="✕" Background="Transparent" Foreground="#AAA" BorderThickness="0" Margin="2" Width="30" Focusable="False"/>
            </Grid>
        </Border>

        <!-- Command Palette Overlay -->
        <Grid Name="CommandPaletteOverlay" ZIndex="999" IsVisible="False" Background="#80000000">
            <Border Width="600" Height="400" Background="#252526" BorderBrush="#007ACC" BorderThickness="1" CornerRadius="4" VerticalAlignment="Top" Margin="0,80,0,0">
                <Grid RowDefinitions="Auto, *">
                    <TextBox Name="CommandSearchBox" Watermark="Type a command..." FontSize="14" Padding="10" BorderThickness="0,0,0,1" BorderBrush="#333333" Background="Transparent" Foreground="White" />
                    <ListBox Name="CommandList" Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Grid ColumnDefinitions="*, 100">
                                    <TextBlock Text="{Binding FullTitle}" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Shortcut}" Foreground="#888888" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
