<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NovaTerminal.MainWindow"
        Title="NovaTerminal"
        Background="Black">
    
    <Grid RowDefinitions="Auto, *">
        <StackPanel Orientation="Horizontal" Background="#202020">
             <!-- Focusable=False to prevent stealing keyboard focus on click -->
             <Button Name="BtnNewTab" Content=" + " Background="Transparent" Foreground="White" BorderThickness="0" Focusable="False"/>
        </StackPanel>
        
        <TabControl Name="Tabs" Grid.Row="1" Background="Black">
            <!-- Tabs added dynamically -->
        </TabControl>
    </Grid>
</Window>
