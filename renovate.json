{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "minor": {
    "automerge": true
  },
  "patch": {
    "automerge": true
  },
  "major": {
    "automerge": false
  }
}
